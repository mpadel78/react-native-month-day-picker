{
  "name": "react-native-month-day-picker",
  "version": "0.1.0",
  "description": "A privacy-friendly birthday picker for React Native that uses only month and day (no year)",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "prepare": "node scripts/prepare.js",
    "test": "jest --watchman=false",
    "test:watch": "jest --watch --watchman=false",
    "test:coverage": "jest --coverage --watchman=false",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test",
    "example": "cd example && npm start"
  },
  "keywords": [
    "react-native",
    "birthday",
    "picker",
    "month",
    "day",
    "date",
    "wheel-picker",
    "expo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpadel78/react-native-month-day-picker.git"
  },
  "author": "mpadel78",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mpadel78/react-native-month-day-picker/issues"
  },
  "homepage": "https://github.com/mpadel78/react-native-month-day-picker#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@quidone/react-native-wheel-picker": "^1.3.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "del-cli": "^5.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "^4.10.1",
    "react-native-builder-bob": "^0.23.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.64.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-gesture-handler": {
      "optional": false
    },
    "react-native-reanimated": {
      "optional": false
    },
    "react-native-safe-area-context": {
      "optional": false
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "eslintConfig": {
    "root": true,
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint",
      "react",
      "react-hooks"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:react/recommended",
      "plugin:react-hooks/recommended",
      "prettier"
    ],
    "settings": {
      "react": {
        "version": "detect"
      }
    },
    "rules": {
      "react/react-in-jsx-scope": "off"
    }
  }
}
